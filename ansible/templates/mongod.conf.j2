# mongod.conf — MongoDB Configuration for TravelMemory
# Managed by Ansible — do not edit manually

# Where and how to store data
storage:
  dbPath: /var/lib/mongodb

# Where to write logging data
systemLog:
  destination: file
  logAppend: true
  path: /var/log/mongodb/mongod.log

# Network interfaces
net:
  port: 27017
  bindIp: 0.0.0.0    # Listen on all interfaces (secured by Security Groups + UFW)

# Process management
processManagement:
  timeZoneInfo: /usr/share/zoneinfo

# Security — enable authentication
security:
  authorization: enabled
